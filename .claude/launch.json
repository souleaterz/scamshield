{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Next.js dev server",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3000,
      "autoPort": true
    },
    {
      "name": "Guardurai Windows UI",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", "guardurai-windows/ui", "-p", "5173", "--no-clipboard"],
      "port": 5173
    }
  ]
}
