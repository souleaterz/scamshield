# --- Required: scam analysis ---
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# --- Optional: usage tracking + daily limit (Supabase) ---
# Until both are set, the daily limit is NOT enforced (the app fails open).
# Project Settings → API. The service-role key is server-only — never expose it.
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Optional: accounts (Clerk) ---
# Until both are set, the app runs anonymously (IP-based limit, no login UI).
# Clerk Dashboard → API Keys.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# --- Optional: subscriptions (Stripe) ---
# Until STRIPE_SECRET_KEY is set, upgrades are disabled and everyone stays free.
# Stripe Dashboard → Developers → API keys (use test keys first).
STRIPE_SECRET_KEY=
# Price IDs for the recurring products you create (Pro £4.99, Unlimited £9.99).
STRIPE_PRICE_PRO=
STRIPE_PRICE_UNLIMITED=
# Signing secret for the webhook endpoint (see SETUP.md). Required for billing to sync.
STRIPE_WEBHOOK_SECRET=

# Public base URL, used for Stripe success/cancel redirects (e.g. https://scamshield.io).
# Optional in dev — falls back to the request origin / http://localhost:3000.
NEXT_PUBLIC_APP_URL=
