# --- Required: scam analysis ---
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# --- Optional: usage tracking + daily limit (Supabase) ---
# Until both are set, the daily limit is NOT enforced (the app fails open).
# Project Settings → API. The service-role key is server-only — never expose it.
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Optional: accounts (Clerk) ---
# Until both are set, the app runs anonymously (IP-based limit, no login UI).
# Clerk Dashboard → API Keys.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# --- Optional: subscriptions (Stripe) ---
# Until STRIPE_SECRET_KEY is set, upgrades are disabled and everyone stays free.
# Stripe Dashboard → Developers → API keys (use test keys first).
STRIPE_SECRET_KEY=
# Price ID for the Pro plan (£4.99/mo recurring, 3-day free trial configured in checkout).
STRIPE_PRICE_PRO=
# Signing secret for the webhook endpoint (see SETUP.md). Required for billing to sync.
STRIPE_WEBHOOK_SECRET=

# Public base URL, used for Stripe success/cancel redirects (e.g. https://guardurai.com).
# Optional in dev — falls back to the request origin / http://localhost:3000.
NEXT_PUBLIC_APP_URL=

# --- Cron secret (required for the Reddit sync cron job) ---
# Set to any random string. Vercel passes it as Authorization: Bearer <CRON_SECRET>
# when invoking /api/cron/sync-reddit-scams. Generate with: openssl rand -hex 32
CRON_SECRET=

# --- Reddit OAuth (required for the Reddit scam-sync cron) ---
# Reddit blocks the anonymous .json endpoint (403) from servers, so the cron
# authenticates with application-only OAuth. Register a "script" app at
# https://www.reddit.com/prefs/apps — the client ID is shown under the app name.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# --- Optional: link reputation (Google Safe Browsing) ---
# Until set, URL checks rely on heuristics + RDAP only (still works, just no Google signal).
# Google Cloud Console → APIs & Services → Credentials → Create API key.
# Enable "Safe Browsing API" on the project. Free tier: 10,000 queries/day.
GOOGLE_SAFE_BROWSING_KEY=

# --- Optional: phone spam reputation (IPQualityScore) ---
# Provides fraud_score, spammer flag, recent_abuse, and carrier for any phone number.
# Until set, phone checks use line-type heuristics only — numbers with no format flags
# will NOT be confirmed safe. Sign up at https://www.ipqualityscore.com
# Free tier: 200 requests/day.
IPQS_API_KEY=

# --- Optional: phone carrier lookup (AbstractAPI) ---
# Secondary carrier source, used only if IPQS_API_KEY is not set.
# Sign up free at https://www.abstractapi.com/api/phone-validation-api
# Free tier: 500 requests/month.
ABSTRACT_API_PHONE_KEY=

# --- Optional: reverse image search (Google Cloud Vision) ---
# Used in "Verify Profile Photo" to find where an image appears on the web.
# Same Google Cloud project as GOOGLE_SAFE_BROWSING_KEY — enable "Cloud Vision API"
# on the project and the same key will work. Free tier: 1,000 units/month.
GOOGLE_CLOUD_VISION_KEY=

# --- Optional: AI-generated image detection (Sightengine) ---
# Detects AI-generated / deepfake profile photos in "Verify Profile Photo".
# Sign up at https://sightengine.com — both USER and SECRET are required.
# Free tier: 100 API calls/month.
SIGHTENGINE_USER=
SIGHTENGINE_SECRET=

# --- Optional: business legitimacy check (Companies House) ---
# Used in "Check Company" to verify UK company registration and status.
# Free API key — register at https://developer.company-information.service.gov.uk/
# The FCA register check runs without a key (public API).
COMPANIES_HOUSE_API_KEY=
